# Local working files / source images that aren't part of the public site
# Keep originals locally for backup, only ship the renamed kira-*.jpg

# Showcase source images (numeric prefixed work files)
assets/showcase/[0-9]*-*.jpg
assets/showcase/[0-9]*-*.jpeg
assets/showcase/[0-9]*-*.png
assets/showcase/.DS_Store

# Original uncompressed images backup (kept locally for re-export)
assets/showcase-orig/

# Original video uploads (use compressed kira-*.mp4 instead)
assets/showcase/copy_*.mov
assets/showcase/copy_*.mp4
assets/showcase/*.MOV

# macOS metadata
.DS_Store
**/.DS_Store

# Editor swap / backup
*.swp
*~
